<Configuration>
  <!-- Update HostFolder to the absolute path of your local share directory -->
  <MappedFolders>
    <MappedFolder>
      <HostFolder>C:\path\to\your\share</HostFolder>
      <SandboxFolder>C:\Shared</SandboxFolder>
      <ReadOnly>false</ReadOnly>
    </MappedFolder>
  </MappedFolders>

  <LogonCommand>
    <Command>powershell.exe -ExecutionPolicy Bypass -File C:\Shared\Invoke-SlideshowBuilder.ps1</Command>
  </LogonCommand>
</Configuration>