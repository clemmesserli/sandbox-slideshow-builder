<Configuration>
  <MappedFolders>
    <MappedFolder>
      <HostFolder>C:\MySandboxShare</HostFolder>
      <SandboxFolder>C:\Shared</SandboxFolder>
      <ReadOnly>false</ReadOnly>
    </MappedFolder>
  </MappedFolders>

  <LogonCommand>
    <Command>powershell.exe -ExecutionPolicy Bypass -File C:\Shared\LetsPlay.ps1</Command>
  </LogonCommand>
</Configuration>